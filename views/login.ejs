<%- include('partials/header') %>

    <!-- Card Container -->
    <div class="w-full max-w-[380px] bg-background border border-zinc-200 rounded-xl p-6 sm:p-8 shadow-[0_1px_3px_rgba(0,0,0,0.05)] transition-all">
        
        <!-- Card Header -->
        <div class="flex flex-col space-y-1.5 text-left mb-6">
            <h2 class="text-xl font-semibold tracking-tight text-zinc-900">Welcome back</h2>
            <p class="text-sm text-muted-foreground">Enter your phone number to receive an OTP verification.</p>
        </div>

        <!-- Feedback Messages -->
        <% if (error) { %>
            <div class="bg-destructive/5 border border-red-200 p-3 mb-4 rounded-lg flex items-start gap-2.5">
                <svg class="h-4 w-4 text-red-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <p class="text-xs text-red-700 font-medium leading-relaxed">
                    <%= error %>
                </p>
            </div>
        <% } %>

        <!-- Card Content / Form -->
        <form action="/login" method="POST" class="space-y-4">
            <div class="space-y-2">
                <label for="phone" class="text-xs font-medium text-zinc-700 tracking-tight block">Phone Number</label>
                <div class="relative rounded-md">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                    </div>
                    <input 
                        type="tel" 
                        name="phone" 
                        id="phone" 
                        required
                        class="pl-9 block w-full rounded-lg border border-zinc-200 bg-transparent text-sm text-zinc-900 py-2 px-3 outline-none transition-all placeholder:text-zinc-400 focus:border-zinc-400 focus:ring-1 focus:ring-zinc-400"
                        placeholder="e.g. 0241234567"
                    >
                </div>
                <!-- <p class="text-[11px] text-muted-foreground tracking-normal">Use <code class="font-mono bg-zinc-100 text-zinc-800 px-1 rounded">0000000000</code> for initial admin simulation access.</p> -->
            </div>

            <!-- Card Footer Action -->
            <div class="pt-2">
                <button 
                    type="submit"
                    class="w-full flex justify-center py-2 px-4 border border-transparent rounded-lg text-sm font-medium text-primary-foreground bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-zinc-950 focus:ring-offset-2 transition-all shadow-sm"
                >
                    Send OTP Validation
                </button>
            </div>
        </form>
    </div>

<%- include('partials/footer') %>